#!/usr/bin/env bash
# srv — maintenance tool for the Hetzner box (167.233.204.214).
#
# Design: every app is a compose stack in /opt/<name>; the shared Caddy stack in
# /opt/caddy routes all HTTPS traffic; stacks meet on the external "edge"
# network. This script auto-discovers stacks (any /opt/* dir with a compose
# file) and domains (site blocks in the Caddyfile), so adding a new service
# needs no changes here.
#
# Install:  scp deploy/srv root@167.233.204.214:/usr/local/bin/srv && ssh root@167.233.204.214 chmod +x /usr/local/bin/srv
# Usage:    srv help
set -euo pipefail

OPT_DIR=/opt
BACKUP_DIR=/opt/backups
KEEP_BACKUPS=14
CADDY_DIR=/opt/caddy
CADDYFILE=$CADDY_DIR/Caddyfile
DISK_WARN_PCT=80
CERT_WARN_DAYS=14

# ---------- helpers ----------

compose_file() { # <dir> -> prints compose filename, rc=1 if none
    local f
    for f in docker-compose.yml docker-compose.prod.yml compose.yml compose.yaml; do
        [ -f "$1/$f" ] && { echo "$f"; return 0; }
    done
    return 1
}

stacks() { # prints absolute dirs of all compose stacks under /opt
    local d
    for d in "$OPT_DIR"/*/; do
        d=${d%/}
        case "$(basename "$d")" in backups|containerd) continue ;; esac
        compose_file "$d" >/dev/null 2>&1 && echo "$d"
    done
}

dc() { # <dir> <compose args...> — docker compose scoped to a stack, runnable from anywhere
    local dir=$1; shift
    docker compose --project-directory "$dir" -f "$dir/$(compose_file "$dir")" "$@"
}

stack_dir() { # <name> -> dir, or die
    local dir="$OPT_DIR/$1"
    [ -d "$dir" ] && compose_file "$dir" >/dev/null 2>&1 || { echo "Nie znam stacka '$1'. Dostępne: $(stacks | xargs -n1 basename | tr '\n' ' ')" >&2; exit 1; }
    echo "$dir"
}

domains() { # site addresses from the Caddyfile (lines that start a site block)
    grep -oE '^[A-Za-z0-9][A-Za-z0-9.-]*\.[A-Za-z]{2,}' "$CADDYFILE" | sort -u
}

health_path() { case "$1" in api.*) echo "/api/health" ;; *) echo "/" ;; esac; }

say() { printf '\n\033[1m== %s ==\033[0m\n' "$*"; }
warn() { printf '\033[33mUWAGA:\033[0m %s\n' "$*"; WARNINGS=$((WARNINGS + 1)); }
ok() { printf '\033[32mOK:\033[0m %s\n' "$*"; }
WARNINGS=0

# ---------- commands ----------

cmd_status() {
    say "Stacki"
    local d
    for d in $(stacks); do
        printf '\n--- %s ---\n' "$d"
        dc "$d" ps --format 'table {{.Name}}\t{{.Status}}\t{{.Image}}'
    done
    say "Zużycie zasobów (kontenery)"
    docker stats --no-stream --format 'table {{.Name}}\t{{.MemUsage}}\t{{.CPUPerc}}'
    say "Dysk i RAM"
    df -h / | tail -1
    free -h | head -2 | tail -1
    say "Sieć edge"
    docker network inspect edge --format '{{range .Containers}}{{.Name}}  {{end}}' 2>/dev/null || warn "sieć edge nie istnieje"
}

cmd_health() {
    say "Zdrowie usług przez Caddy (HTTPS)"
    local d code
    for d in $(domains); do
        code=$(curl -sS -m 10 -o /dev/null -w '%{http_code}' "https://$d$(health_path "$d")" 2>/dev/null || echo "000")
        if [ "$code" -ge 200 ] && [ "$code" -lt 500 ]; then ok "$d -> HTTP $code"; else warn "$d -> HTTP $code"; fi
    done
}

cmd_certs() {
    say "Certyfikaty TLS"
    local d exp exp_s now_s days
    for d in $(domains); do
        exp=$(echo | openssl s_client -servername "$d" -connect "$d:443" 2>/dev/null | openssl x509 -noout -enddate 2>/dev/null | cut -d= -f2) || true
        if [ -z "${exp:-}" ]; then warn "$d: nie udało się pobrać certyfikatu"; continue; fi
        exp_s=$(date -d "$exp" +%s 2>/dev/null || date -j -f '%b %e %T %Y %Z' "$exp" +%s)
        now_s=$(date +%s)
        days=$(( (exp_s - now_s) / 86400 ))
        if [ "$days" -lt "$CERT_WARN_DAYS" ]; then warn "$d: certyfikat wygasa za ${days} dni ($exp)"; else ok "$d: ${days} dni do wygaśnięcia"; fi
    done
}

cmd_logs() {
    local dir; dir=$(stack_dir "${1:?użycie: srv logs <stack> [ile-linii]}")
    dc "$dir" logs --tail "${2:-100}"
}

cmd_restart() {
    local dir; dir=$(stack_dir "${1:?użycie: srv restart <stack>}")
    dc "$dir" restart
    ok "zrestartowano $(basename "$dir")"
}

cmd_update() {
    # pobiera nowe obrazy i podnosi stack(i); "all" = wszystkie poza caddy
    local target=${1:?użycie: srv update <stack|all>} d
    if [ "$target" = all ]; then
        for d in $(stacks); do
            [ "$d" = "$CADDY_DIR" ] && continue
            say "update $(basename "$d")"
            dc "$d" pull && dc "$d" up -d
        done
    else
        d=$(stack_dir "$target")
        dc "$d" pull && dc "$d" up -d
    fi
    docker image prune -f >/dev/null
    ok "obrazy zaktualizowane, stare wyczyszczone"
}

cmd_caddy_reload() {
    # Pułapka bind-mounta pojedynczego pliku: sed -i / edytory tworzą NOWY inode,
    # a kontener dalej widzi stary plik. Przy rozjeździe trzeba odtworzyć kontener.
    local host_sum cont_sum
    host_sum=$(md5sum "$CADDYFILE" | cut -d' ' -f1)
    cont_sum=$(dc "$CADDY_DIR" exec -T caddy md5sum /etc/caddy/Caddyfile | cut -d' ' -f1)
    if [ "$host_sum" != "$cont_sum" ]; then
        warn "Caddyfile w kontenerze różni się od /opt/caddy/Caddyfile (stary inode po edycji) - odtwarzam kontener"
        dc "$CADDY_DIR" up -d --force-recreate
        sleep 2
    fi
    dc "$CADDY_DIR" exec -T caddy caddy validate --config /etc/caddy/Caddyfile
    dc "$CADDY_DIR" exec -T caddy caddy reload --config /etc/caddy/Caddyfile
    ok "Caddyfile zwalidowany i przeładowany"
}

cmd_backup() {
    local dest="$BACKUP_DIR/$(date +%F_%H%M)"
    mkdir -p "$dest"
    say "Backup -> $dest"

    # 1. Postgres ochrony (spójny dump)
    if [ -d "$OPT_DIR/ochrona" ]; then
        dc "$OPT_DIR/ochrona" exec -T db pg_dump -U ochrona ochronazklasa | gzip > "$dest/ochrona-db.sql.gz" \
            && ok "ochrona: pg_dump" || warn "ochrona: pg_dump nie powiódł się"
    fi

    # 2. SQLite ozk-api (spójna kopia online przez better-sqlite3)
    if [ -d "$OPT_DIR/ozk-api" ]; then
        if dc "$OPT_DIR/ozk-api" exec -T ozk-api node -e \
            "require('better-sqlite3')('/app/data/wnioski.sqlite').backup('/app/data/backup-tmp.sqlite').then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})"; then
            dc "$OPT_DIR/ozk-api" cp ozk-api:/app/data/backup-tmp.sqlite "$dest/ozk-api-wnioski.sqlite"
            dc "$OPT_DIR/ozk-api" exec -T ozk-api rm -f /app/data/backup-tmp.sqlite
            ok "ozk-api: kopia SQLite"
        else
            warn "ozk-api: kopia SQLite nie powiodła się"
        fi
    fi

    # 3. Konfiguracja: Caddyfile + pliki .env wszystkich stacków
    cp "$CADDYFILE" "$dest/Caddyfile"
    local d name
    for d in $(stacks); do
        name=$(basename "$d")
        [ -f "$d/.env" ] && cp "$d/.env" "$dest/env-$name"
        cp "$d/$(compose_file "$d")" "$dest/compose-$name.yml"
    done
    chmod -R go-rwx "$dest"
    ok "konfiguracja: Caddyfile + .env + compose"

    # 4. Retencja
    ls -1dt "$BACKUP_DIR"/*/ 2>/dev/null | tail -n +$((KEEP_BACKUPS + 1)) | xargs -r rm -rf
    say "Rozmiar backupów"
    du -sh "$BACKUP_DIR"
}

cmd_doctor() {
    say "Diagnostyka serwera"

    # kontenery
    local unhealthy
    unhealthy=$(docker ps --filter health=unhealthy --format '{{.Names}}')
    [ -n "$unhealthy" ] && warn "niezdrowe kontenery: $unhealthy" || ok "wszystkie kontenery zdrowe"
    local restarting
    restarting=$(docker ps --filter status=restarting --format '{{.Names}}')
    [ -n "$restarting" ] && warn "kontenery w pętli restartu: $restarting" || true

    # dysk
    local pct
    pct=$(df --output=pcent / | tail -1 | tr -dc '0-9')
    [ "$pct" -ge "$DISK_WARN_PCT" ] && warn "dysk zapełniony w ${pct}%" || ok "dysk: ${pct}% zajęte"

    # świeżość backupu
    local last
    last=$(ls -1dt "$BACKUP_DIR"/*/ 2>/dev/null | head -1 || true)
    if [ -z "$last" ]; then
        warn "brak jakiegokolwiek backupu w $BACKUP_DIR"
    elif [ -n "$(find "$last" -maxdepth 0 -mtime +2)" ]; then
        warn "ostatni backup starszy niż 2 dni: $last"
    else
        ok "ostatni backup: $last"
    fi

    # sieć edge: caddy musi w niej być
    docker network inspect edge --format '{{range .Containers}}{{.Name}} {{end}}' 2>/dev/null | grep -q caddy \
        && ok "caddy jest w sieci edge" || warn "caddy NIE jest w sieci edge"

    cmd_health
    cmd_certs

    say "Wynik"
    if [ "$WARNINGS" -eq 0 ]; then ok "wszystko w porządku"; else warn "liczba ostrzeżeń: $WARNINGS"; fi
}

cmd_help() {
    cat <<'EOF'
srv — utrzymanie serwera (stacki compose w /opt, wspólne Caddy, sieć edge)

  srv status              stan wszystkich stacków, zasoby, sieć edge
  srv health              testy HTTP wszystkich domen z Caddyfile
  srv certs               daty wygaśnięcia certyfikatów TLS
  srv doctor              pełna diagnostyka (kontenery, dysk, backupy, health, certy)
  srv logs <stack> [n]    ostatnie n linii logów stacka (domyślnie 100)
  srv restart <stack>     restart stacka
  srv update <stack|all>  pull nowych obrazów + up -d (+ czyszczenie starych obrazów)
  srv caddy-reload        walidacja i przeładowanie Caddyfile (zero downtime)
  srv backup              backup: pg_dump ochrony, SQLite ozk-api, Caddyfile, .env-y
  srv help                ta pomoc

Stacki wykrywane automatycznie: każdy katalog /opt/<nazwa> z plikiem compose.
Domeny wykrywane automatycznie z /opt/caddy/Caddyfile.
Cron (backup co noc 3:00):  0 3 * * * /usr/local/bin/srv backup >> /var/log/srv-backup.log 2>&1
EOF
}

case "${1:-help}" in
    status)       cmd_status ;;
    health)       cmd_health ;;
    certs)        cmd_certs ;;
    doctor)       cmd_doctor ;;
    logs)         shift; cmd_logs "$@" ;;
    restart)      shift; cmd_restart "$@" ;;
    update)       shift; cmd_update "$@" ;;
    caddy-reload) cmd_caddy_reload ;;
    backup)       cmd_backup ;;
    help|--help|-h) cmd_help ;;
    *) echo "Nieznana komenda: $1"; cmd_help; exit 1 ;;
esac
